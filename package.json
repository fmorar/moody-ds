{
  "name": "moody-ds",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "docs": "turbo dev --filter=@moody-ds/docs",
    "storybook": "turbo dev --filter=@moody-ds/storybook"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.6.0"
  }
}
